{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DimiLinks API",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "指南",
        "groups": [
          {
            "group": "开始使用",
            "pages": [
              "index",
              "quickstart"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "基础",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/models",
              "api-reference/errors"
            ]
          },
          {
            "group": "对话 / Chat",
            "pages": [
              "api-reference/chat/completions",
              "api-reference/chat/anthropic-messages"
            ]
          },
          {
            "group": "图片 / gpt-image-2",
            "pages": [
              "api-reference/images/gpt-image-2/generation",
              "api-reference/images/gpt-image-2/edits",
              "api-reference/images/gpt-image-2/tasks",
              "api-reference/images/gpt-image-2/sizes"
            ]
          },
          {
            "group": "视频 / grok-imagine-video",
            "pages": [
              "api-reference/videos/grok-imagine-video/generation",
              "api-reference/videos/grok-imagine-video/tasks"
            ]
          },
          {
            "group": "IDE 与 CLI 接入",
            "pages": [
              "api-reference/integrations/ccswitch",
              "api-reference/integrations/claude-code",
              "api-reference/integrations/codex-cli",
              "api-reference/integrations/vscode-and-ides"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "主页",
          "href": "https://dimilinks.com",
          "icon": "house"
        },
        {
          "anchor": "控制台",
          "href": "https://dimilinks.com/console",
          "icon": "gauge-high"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "主页",
        "href": "https://dimilinks.com"
      },
      {
        "label": "价格",
        "href": "https://dimilinks.com/pricing"
      }
    ],
    "primary": {
      "type": "button",
      "label": "打开控制台",
      "href": "https://dimilinks.com/console"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.dimilinks.com"
    }
  },
  "footer": {
    "socials": {}
  }
}
